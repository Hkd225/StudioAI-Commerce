        "\n",
        "def generate_image(pipe, prompt, neg_prompt, seed, steps, cfg, num_images=1, scheduler_name=\"Euler A\"):\n",
        "\n",
        "    # Setup Generator (Seed)\n",
        "    generator = torch.Generator(device=DEVICE).manual_seed(int(seed))\n",
        "\n",
        "    # Generate gambar standard\n",
        "    image = pipe(\n",
