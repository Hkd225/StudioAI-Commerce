        "        negative_prompt=neg_prompt,\n",
        "        generator=generator,\n",
        "        num_inference_steps=int(steps),\n",
        "        guidance_scale=float(cfg),\n",
        "    ).images[0]\n",
        "\n",
        "    # Kembalikan dalam bentuk List agar kompatibel dengan UI (List isi 1 gambar)\n",
        "    return [image]\n"
